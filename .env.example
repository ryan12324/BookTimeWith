# Book Time With — environment (phase-2 integrations)
# Copy to .env.local and fill in. The UI runs without any of these; they wire up
# the real backend (billing, email, database, calendar sync).

# --- Database (Neon/Supabase Postgres, or Cloudflare D1) ---
DATABASE_URL="postgres://user:pass@host:5432/booktimewith"

# --- Domains ---
NEXT_PUBLIC_APP_URL="https://booktimewith.com"
NEXT_PUBLIC_BOOKING_URL="https://booktimewith.link"

# --- Stripe (one product, multi-currency prices; 30-day trial no card) ---
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_GBP="price_..."
STRIPE_PRICE_USD="price_..."
STRIPE_PRICE_EUR="price_..."
STRIPE_PRICE_AUD="price_..."

# --- Cloudflare Email (outbound transactional via Email Worker / MailChannels) ---
# Client-facing From is "{Owner} via booktimewith.com"; Reply-To = owner's email.
EMAIL_FROM_DOMAIN="mail.booktimewith.com"
CLOUDFLARE_EMAIL_TOKEN=""

# --- Auth (owner magic-link only; clients never have accounts) ---
AUTH_TOKEN_SECRET="generate-a-long-random-string"

# --- Calendar sync ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""

# --- Anti-abuse (Cloudflare Turnstile, shown only when rate limits trip) ---
TURNSTILE_SECRET_KEY=""
