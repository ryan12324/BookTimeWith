# Book Time With — copy to .env.local or configure in Coolify.

# PostgreSQL. Required in every environment. Add the provider's sslmode query
# parameter for managed databases (normally sslmode=require or verify-full).
DATABASE_URL="postgresql://booktimewith:change-me@localhost:5432/booktimewith"
DATABASE_POOL_MAX="10"
DATABASE_CONNECT_TIMEOUT_MS="10000"
DATABASE_IDLE_TIMEOUT_MS="30000"
PORT=3000

# Set true only when the app origin is unreachable directly and your edge
# strips/replaces CF-Connecting-IP, X-Forwarded-For, and X-Real-IP.
TRUST_PROXY_HEADERS="false"

# Canonical domains.
APP_URL="https://booktimewith.com"
BOOKING_URL="https://booktimewith.link"

# REQUIRED in production. Leave examples empty so a copied file cannot boot
# with public credentials; generate independent values before deployment.
AUTH_TOKEN_SECRET=""
CRON_SECRET=""

# Optional independent salts/keys. AUTH_TOKEN_SECRET is the secure fallback for
# both, but separate values make rotation and operational boundaries clearer.
RATE_LIMIT_SECRET=""
CALENDAR_TOKEN_SECRET=""

# Outbound email. Required to deliver live auth, booking, and billing messages.
EMAIL_WEBHOOK_URL=""
EMAIL_FROM_DOMAIN="mail.booktimewith.com"
CLOUDFLARE_EMAIL_TOKEN=""

# Google / Microsoft calendar OAuth. Register this callback on each provider:
# https://booktimewith.com/api/calendar/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""

# Cloudflare Turnstile. Configure both halves or neither; the widget appears
# only after a public booking rate limit is exceeded.
TURNSTILE_SECRET_KEY=""
TURNSTILE_SITE_KEY=""

# Stripe: one recurring product with a price for each supported currency.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_GBP=""
STRIPE_PRICE_USD=""
STRIPE_PRICE_EUR=""
STRIPE_PRICE_AUD=""
