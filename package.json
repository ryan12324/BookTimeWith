{
  "name": "booktimewith",
  "version": "0.1.0",
  "private": true,
  "description": "Book Time With — the un-software for booking clients. Deliberately minimal scheduling for service businesses.",
  "scripts": {
    "dev": "next dev",
    "dev:docker": "docker compose -f docker-compose.dev.yml up",
    "dev:docker:down": "docker compose -f docker-compose.dev.yml down",
    "dev:docker:reset": "docker compose -f docker-compose.dev.yml down -v",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit --incremental false",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run lint && npm run typecheck && npm test && npm run build",
    "db:generate": "drizzle-kit generate",
    "db:import:pglite": "node scripts/import-pglite.mjs"
  },
  "dependencies": {
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "drizzle-orm": "^0.45.2",
    "next": "^15.5.20",
    "pg": "^8.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-email": "^6.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.4",
    "@eslint/eslintrc": "^3.3.1",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.5.20",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
